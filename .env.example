# 学习管家 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# Flask配置
FLASK_SECRET_KEY=your-secret-key-here
FLASK_ENV=production
FLASK_PORT=5000

# 数据库配置
DATABASE_URL=sqlite:///data/learning_manager.db

# 大模型API配置（支持多Key，用逗号分隔）
LLM_API_KEYS=sk-your-api-key-1,sk-your-api-key-2
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# 秘塔搜索API配置
MITA_API_KEY=your-mita-api-key
MITA_API_BASE=https://api.metaso.cn/v1
MITA_DAILY_LIMIT=80

# 钉钉Webhook配置
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
DINGTALK_SECRET=your-secret

# 微信公众号配置（可选）
WECHAT_APP_ID=your-app-id
WECHAT_APP_SECRET=your-app-secret
WECHAT_TEMPLATE_ID=your-template-id

# Server酱配置（可选）
SERVERCHAN_KEY=your-serverchan-key

# GitHub配置
GITHUB_TOKEN=ghp-your-token
GITHUB_REPO=your-username/learning-content
GITHUB_BRANCH=main

# NAS配置
NAS_BASE_URL=https://your-nas-url
NAS_IMAGE_PATH=/data/images

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
